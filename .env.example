RCS_HOST=https://192.168.1.100
APP_KEY=
APP_SECRET=

# Optional RCS call hardening
RCS_REQUEST_TIMEOUT_MS=15000
RCS_ALLOW_INSECURE_TLS=false
RCS_OPERATOR_TOKEN=
RCS_ALLOWED_CLIENT_IPS=
RCS_CALLBACK_TOKEN=

# USB build: set to true only when you intentionally want to copy .env.local.
USB_COPY_ENV=false
